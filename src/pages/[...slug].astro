---
// 블로그 글을 루트 경로(/<slug>)로 서빙하는 동적 라우트
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content, headings } = await render(post);

// 본문 마크다운에서 FAQ(**Q. …** / A. …)를 자동 추출해 FAQPage 구조화 데이터로 넘긴다.
const stripMd = (s: string) =>
	s
		.replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // 링크 → 텍스트
		.replace(/[*_`]/g, '') // 강조 기호 제거
		.replace(/\s+/g, ' ')
		.trim();
const faq: { q: string; a: string }[] = [];
const faqRe = /\*\*Q\.\s*([^*]+?)\*\*\s*\n+A\.\s*([\s\S]*?)(?=\n\s*\n|\n\*\*Q\.|$)/g;
let fm: RegExpExecArray | null;
while ((fm = faqRe.exec(post.body ?? '')) !== null) {
	faq.push({ q: stripMd(fm[1]), a: stripMd(fm[2]) });
}
---

<BlogPost {...post.data} faq={faq} headings={headings}>
	<Content />
</BlogPost>

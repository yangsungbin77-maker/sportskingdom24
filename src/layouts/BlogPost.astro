---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Heading = { depth: number; slug: string; text: string };
type Props = CollectionEntry<'blog'>['data'] & {
	faq?: { q: string; a: string }[];
	headings?: Heading[];
};

const { title, description, pubDate, updatedDate, heroImage, faq, headings = [] } = Astro.props;
const toc = headings.filter((h) => h.depth === 2);
---

<html lang="ko">
	<head>
		<BaseHead
				title={title}
				description={description}
				image={heroImage}
				type="article"
				publishedTime={pubDate}
				modifiedTime={updatedDate}
				faq={faq}
			/>
		<style>
			.article {
				width: 760px;
				max-width: 100%;
				margin: 0 auto;
			}
			.toc {
				background: var(--bg-elev);
				border: 1px solid var(--border);
				border-left: 4px solid var(--accent);
				border-radius: var(--radius-sm);
				padding: 1em 1.3em;
				margin: 0 0 2.2rem;
			}
			.toc-title { display: block; font-weight: 800; color: var(--ink); margin-bottom: 0.5em; font-size: 0.95rem; }
			.toc ol { margin: 0; padding-left: 1.3em; }
			.toc li { margin: 0.3em 0; }
			.toc a { color: var(--text-muted); text-decoration: none; }
			.toc a:hover { color: var(--accent); text-decoration: underline; }
			.back {
				display: inline-block;
				margin-bottom: 1.5rem;
				color: var(--text-muted);
				font-weight: 600;
				font-size: 0.9rem;
			}
			.back:hover { color: var(--accent); }
			.hero-image img {
				display: block;
				width: 100%;
				margin: 0 0 2rem;
				border-radius: var(--radius);
				border: 1px solid var(--border);
			}
			.post-title {
				margin-bottom: 2rem;
				padding-bottom: 1.5rem;
				border-bottom: 1px solid var(--border);
			}
			.post-title h1 {
				font-size: clamp(2rem, 5vw, 3rem);
				margin: 0.6rem 0;
			}
			.date {
				color: var(--text-dim);
				font-size: 0.9rem;
				font-weight: 600;
			}
			.last-updated-on { font-style: italic; }
			.prose {
				color: var(--text);
				font-size: 1.05rem;
			}
			.prose :global(h2) { margin-top: 2.2rem; }
			.prose :global(h3) { margin-top: 1.8rem; }
			.prose :global(a) { text-decoration: underline; text-underline-offset: 3px; }
			.prose :global(ul),
			.prose :global(ol) { padding-left: 1.3em; }
			.prose :global(li) { margin-bottom: 0.4em; }

			/* 표 — 보기 좋게 */
			.prose :global(table) {
				width: 100%;
				border-collapse: collapse;
				margin: 0 0 1.8em;
				font-size: 0.97rem;
				border: 1px solid var(--border);
				border-radius: var(--radius-sm);
				overflow: hidden;
			}
			.prose :global(thead th) {
				background: var(--ink);
				color: #fff;
				font-weight: 700;
				text-align: left;
			}
			.prose :global(th),
			.prose :global(td) {
				padding: 0.7em 0.95em;
				border-bottom: 1px solid var(--border);
				border-right: 1px solid var(--border);
				vertical-align: top;
			}
			.prose :global(tbody tr:nth-child(even)) { background: rgba(20, 22, 27, 0.03); }
			.prose :global(tbody tr:hover) { background: var(--accent-soft); }
			.prose :global(tr:last-child td) { border-bottom: none; }
			.prose :global(th:last-child),
			.prose :global(td:last-child) { border-right: none; }

			/* 콜아웃 박스 */
			.prose :global(.cg-box) {
				border: 1px solid var(--border);
				border-left: 4px solid var(--accent);
				background: var(--bg-elev);
				border-radius: var(--radius-sm);
				padding: 1em 1.3em;
				margin: 0 0 1.7em;
			}
			.prose :global(.cg-box > :first-child) { margin-top: 0; }
			.prose :global(.cg-box > :last-child) { margin-bottom: 0; }
			.prose :global(.cg-box p) { margin: 0.4em 0; }
			.prose :global(.cg-box .cg-title) {
				display: block;
				font-weight: 800;
				color: var(--ink);
				margin-bottom: 0.35em;
			}
			.prose :global(.cg-summary) { border-left-color: var(--accent); background: var(--accent-soft); }
			.prose :global(.cg-tip)     { border-left-color: #34d399; background: rgba(52, 211, 153, 0.08); }
			.prose :global(.cg-warn)    { border-left-color: #fbbf24; background: rgba(251, 191, 36, 0.09); }
			.prose :global(.cg-danger)  { border-left-color: #f87171; background: rgba(248, 113, 113, 0.10); }

			@media (max-width: 720px) {
				.prose :global(table) { display: block; overflow-x: auto; white-space: nowrap; }
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article class="article">
				<a href="/blog" class="back">← 전체 글로</a>
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt={title} />
					</div>
				)}
				<div class="post-title">
					<span class="tag">SPORTSKINGDOM24</span>
					<h1>{title}</h1>
					<div class="date">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<span class="last-updated-on">
									 · 마지막 수정 <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>
				</div>
				{toc.length >= 3 && (
					<nav class="toc" aria-label="목차">
						<span class="toc-title">목차</span>
						<ol>
							{toc.map((h) => (
								<li><a href={`#${h.slug}`}>{h.text}</a></li>
							))}
						</ol>
					</nav>
				)}
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

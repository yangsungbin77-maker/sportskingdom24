---
// 모든 페이지의 <head> 메타·SEO·구조화 데이터를 담당하는 공통 컴포넌트
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE, GSC_VERIFICATION } from '../consts';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	type?: 'website' | 'article';
	publishedTime?: Date;
	modifiedTime?: Date;
	faq?: { q: string; a: string }[];
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
	title,
	description,
	image = FallbackImage,
	type = 'website',
	publishedTime,
	modifiedTime,
	faq = [],
} = Astro.props;
const imageURL = new URL(image.src, Astro.site);

// 기사 페이지에는 여러 구조화 데이터(JSON-LD)를 넣어 구글 리치 결과를 노린다.
const schemas: object[] = [];
if (type === 'article') {
	schemas.push({
		'@context': 'https://schema.org',
		'@type': 'BlogPosting',
		headline: title,
		description,
		image: imageURL.href,
		datePublished: publishedTime?.toISOString(),
		dateModified: (modifiedTime ?? publishedTime)?.toISOString(),
		author: { '@type': 'Organization', name: SITE_TITLE, url: Astro.site?.href },
		publisher: {
			'@type': 'Organization',
			name: SITE_TITLE,
			logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.site).href },
		},
		mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalURL.href },
	});

	// 빵부스러기(경로) — 검색결과에 사이트 > 블로그 > 글 경로 노출
	schemas.push({
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: SITE_TITLE, item: Astro.site?.href },
			{ '@type': 'ListItem', position: 2, name: '블로그', item: new URL('/blog', Astro.site).href },
			{ '@type': 'ListItem', position: 3, name: title, item: canonicalURL.href },
		],
	});

	// FAQ가 있으면 FAQPage — 검색결과에 Q&A가 펼쳐져 클릭률↑
	if (faq.length > 0) {
		schemas.push({
			'@context': 'https://schema.org',
			'@type': 'FAQPage',
			mainEntity: faq.map((f) => ({
				'@type': 'Question',
				name: f.q,
				acceptedAnswer: { '@type': 'Answer', text: f.a },
			})),
		});
	}
}
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<!-- Google AdSense -->
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8312549013849190" crossorigin="anonymous" is:inline></script>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
{GSC_VERIFICATION && <meta name="google-site-verification" content={GSC_VERIFICATION} />}

<Font cssVariable="--font-atkinson" preload />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:locale" content="ko_KR" />
{type === 'article' && publishedTime && (
	<meta property="article:published_time" content={publishedTime.toISOString()} />
)}
{type === 'article' && (modifiedTime ?? publishedTime) && (
	<meta property="article:modified_time" content={(modifiedTime ?? publishedTime)!.toISOString()} />
)}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />

<!-- Structured data -->
{schemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
